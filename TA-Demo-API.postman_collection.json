              "body": "{\n  \"success\": true,\n  \"message\": \"No wishlist items available\",\n  \"reservationId\": null\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "WhatsApp",
      "item": [
        {
          "name": "Button Response",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageId\": \"2025-12-18T12:00:00.000Z\",\n  \"buttonId\": \"reserve_item\",\n  \"buttonText\": \"Reserve Item\",\n  \"sender\": \"Zara\",\n  \"senderNumber\": \"+1-800-SHOP\",\n  \"payload\": {\n    \"reservationId\": \"clxyz123456789\",\n    \"action\": \"reserve\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/whatsapp/button-response",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "whatsapp", "button-response"]
            },
            "description": "Handles button clicks from WhatsApp messages. Confirms or declines reservations and sends SSE events to store associate app."
          },
          "response": [
            {
              "name": "Reserve Item - Confirmed",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"messageId\": \"2025-12-18T12:00:00.000Z\",\n  \"buttonId\": \"reserve_item\",\n  \"buttonText\": \"Reserve Item\",\n  \"sender\": \"Zara\",\n  \"senderNumber\": \"+1-800-SHOP\",\n  \"payload\": {\n    \"reservationId\": \"clxyz123456789\",\n    \"action\": \"reserve\"\n  }\n}"
                },
                "url": {
                  "raw": "http://localhost:3000/api/whatsapp/button-response",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "3000",
                  "path": ["api", "whatsapp", "button-response"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Reservation confirmed\",\n  \"reservation\": {\n    \"id\": \"clxyz123456789\",\n    \"status\": \"CONFIRMED\"\n  }\n}"
            },
            {
              "name": "No Thanks - Declined",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"messageId\": \"2025-12-18T12:00:00.000Z\",\n  \"buttonId\": \"no_thanks\",\n  \"buttonText\": \"No Thanks\",\n  \"sender\": \"Zara\",\n  \"senderNumber\": \"+1-800-SHOP\",\n  \"payload\": {\n    \"reservationId\": \"clxyz123456789\",\n    \"action\": \"decline\"\n  }\n}"
                },
                "url": {
                  "raw": "http://localhost:3000/api/whatsapp/button-response",
                  "protocol": "http",
