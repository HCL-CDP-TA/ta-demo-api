                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"user-999\",\n  \"geofenceId\": \"geofence-001\",\n  \"geofenceName\": \"Westfield Mall\",\n  \"phoneNumber\": \"+1-555-9999\",\n  \"timestamp\": \"2025-12-18T12:00:00Z\",\n  \"position\": {\n    \"latitude\": 34.0522,\n    \"longitude\": -118.2437,\n    \"accuracy\": 10\n  }\n}"
                },
                "url": {
                  "raw": "http://localhost:3000/api/webhooks/geofence-entry",
                  "protocol": "http",
