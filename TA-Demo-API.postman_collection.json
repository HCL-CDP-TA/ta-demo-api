{
  "info": {
    "name": "TA Demo API",
    "description": "API for orchestrating geofence-to-WhatsApp-to-reservation demo flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "ta-demo-api"
  },
  "item": [
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Geofence Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "demo-webhook-secret-2025",
                "description": "Webhook API key for authentication"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-001\",\n  \"geofenceId\": \"geofence-001\",\n  \"geofenceName\": \"Westfield Mall\",\n  \"phoneNumber\": \"+1-555-0001\",\n  \"timestamp\": \"2025-12-18T12:00:00Z\",\n  \"position\": {\n    \"latitude\": 34.0522,\n    \"longitude\": -118.2437,\n    \"accuracy\": 10\n  },\n  \"metadata\": {\n    \"name\": \"Sarah Johnson\",\n    \"email\": \"sarah.johnson@example.com\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/webhooks/geofence-entry",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "webhooks", "geofence-entry"]
            },
            "description": "Receives CDP webhook when a user enters a shopping centre geofence. Creates a pending reservation and sends WhatsApp message with product from user's wishlist."
          },
          "response": [
            {
              "name": "Success - WhatsApp Sent",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"user-001\",\n  \"geofenceId\": \"geofence-001\",\n  \"geofenceName\": \"Westfield Mall\",\n  \"phoneNumber\": \"+1-555-0001\",\n  \"timestamp\": \"2025-12-18T12:00:00Z\",\n  \"position\": {\n    \"latitude\": 34.0522,\n    \"longitude\": -118.2437,\n    \"accuracy\": 10\n  }\n}"
                },
                "url": {
                  "raw": "http://localhost:3000/api/webhooks/geofence-entry",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "3000",
                  "path": ["api", "webhooks", "geofence-entry"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Geofence entry processed successfully\",\n  \"reservationId\": \"clxyz123456789\",\n  \"whatsappSent\": true\n}"
            },
            {
