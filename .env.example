# Database - Uses the multitenant PostgreSQL database
DATABASE_URL=

# Phone Emulator Integration
PHONE_EMULATOR_URL=

# API Base URL (where this API is hosted - used for webhook callbacks)
API_BASE_URL=

# CDP Integration (Update with your actual credentials)
CDP_ENDPOINT="https://crux.dev.hxcd.now.hclsoftware.cloud"
CDP_API_KEY=""
CDP_PASS_KEY=""

# Webhook Security
WEBHOOK_API_KEY=

# Business Rules
COB_TIME="17:00"
DEFAULT_SHOPPING_CENTRE="Westfield Mall"
DEFAULT_STORE="Zara"

# Feature Flags
ENABLE_CDP_TRACKING=true
ENABLE_WHATSAPP=true
ENABLE_SSE=true

# Logging
LOG_LEVEL="info"

# Deployment
NODE_ENV="production"
PORT="3300"
ENVIRONMENT="production"

# HCL Commerce API Configuration
# Update these values with your actual Commerce instance
COMMERCE_HOST_URL=https://commerce-preview.comdx.demo.com
COMMERCE_STORE_HOST=https://commerce-preview.comdx.demo.com
COMMERCE_TRANSACTION_CONTEXT="/wcs/resources"
COMMERCE_SEARCH_CONTEXT="/search/resources"
COMMERCE_STORE_ID="41"
COMMERCE_CATALOG_ID="11501"
COMMERCE_CONTRACT_ID="-41005"
COMMERCE_VERSION="commerce-9x"
COMMERCE_STORE_NAME="Ruby"
COMMERCE_FULFILLMENT_CENTER="R00B2C"

# Commerce Service Account (optional, for admin access to user data)
COMMERCE_ADMIN_USER=csrAdmin
COMMERCE_ADMIN_PASSWORD=

TA_DEMO_API_URL=http://localhost:3300

CDP_ENDPOINT="https://crux.dev.hxcd.now.hclsoftware.cloud"
CDP_API_KEY=
CDP_PASS_KEY=